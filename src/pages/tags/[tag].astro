---
import Layout from '../../layouts/Layout.astro';
import OtherBlogListing from '../../components/OtherBlogListing.astro';
import TopicBrowse from '../../components/TopicBrowse.astro';
import type BlogData from '../../interfaces/blogHighlight';
import type TagData from '../../interfaces/tag';
import { fetchArticles } from '../../utils/blogApi';
import { getCategoryDiscoveryConfig } from '../../utils/categoryDiscovery';
import { getPopularTags, normalizeSecondaryCategories } from '../../utils/tags';

type PrimaryTagCategory = { name: string; slug: string };

export async function getStaticPaths() {
  const articleResponse = await fetchArticles({ limit: 1000, fieldSet: 'listing' });
  const allPosts = articleResponse.articles.items as BlogData[];
  const tagMap = new Map<string, TagData>();

  const getPrimaryTagCategory = (posts: BlogData[]): PrimaryTagCategory | undefined => {
    const categories = new Map<string, PrimaryTagCategory & { count: number; latestPostTime: number }>();

    posts.forEach((post) => {
      const slug = post.category.toLowerCase();
      const existing = categories.get(slug);
      const latestPostTime = new Date(post.date).getTime();

      categories.set(slug, {
        count: (existing?.count ?? 0) + 1,
        latestPostTime: Math.max(existing?.latestPostTime ?? 0, Number.isNaN(latestPostTime) ? 0 : latestPostTime),
        name: getCategoryDiscoveryConfig(slug)?.name ?? post.category,
        slug,
      });
    });

    return Array.from(categories.values()).sort((firstCategory, secondCategory) =>
      secondCategory.count - firstCategory.count
      || secondCategory.latestPostTime - firstCategory.latestPostTime
      || firstCategory.name.localeCompare(secondCategory.name),
    )[0];
  };

  allPosts.forEach((post) => {
    normalizeSecondaryCategories(post.secondaryCategories).forEach((tag) => {
      tagMap.set(tag.slug, tag);
    });
  });

  return Array.from(tagMap.values()).map((tag) => ({
    params: { tag: tag.slug },
    props: (() => {
      const posts = allPosts.filter((post) =>
        normalizeSecondaryCategories(post.secondaryCategories).some((postTag) => postTag.slug === tag.slug),
      );

      return {
        tag,
        posts,
        primaryCategory: getPrimaryTagCategory(posts),
        browseTags: getPopularTags(posts, { limit: 12, minCount: 1 }).filter((browseTag) => browseTag.slug !== tag.slug),
      };
    })(),
  }));
}

const { tag, posts, primaryCategory, browseTags } = Astro.props as {
  tag: TagData;
  posts: BlogData[];
  primaryCategory?: PrimaryTagCategory;
  browseTags: TagData[];
};
---

<Layout
  title={`Posts about ${tag.label}`}
  metaDescription={`Browse blog posts about ${tag.label}.`}
  currentUrl={`/tags/${tag.slug}`}
  categoryURL={primaryCategory?.slug}
  categoryName={primaryCategory?.name}
>
  <div class="max-w-[1564px] mx-auto md:px-8-px">
    <div class="text-lt-gray dark:text-dk-gray py-2 px-4-px max-w-xl mx-auto md:py-6 md:px-8-px lg:max-w-4xl">
      <h1 id="skip-target" class="block px-4-px font-bold text-center mt-8 lg:mt-16 mb-4 lg:mb-8 text-4xl md:text-5xl text-lt-gray-heading dark:text-dk-gray-heading">
        {tag.label}
      </h1>
    </div>
  </div>

  <TopicBrowse tags={browseTags} />

  <section class="max-w-7xl mx-4-px mb-8 md:mb-12 xl:mt-0 xl:mx-auto" slot="blogs" aria-label="Blog listing">
    <ul class="grid grid-cols-1 gap-y-8 md:grid-cols-2 md:gap-8 lg:grid-cols-3 lg:gap-12" role="list">
      <OtherBlogListing posts={posts} />
    </ul>
  </section>
</Layout>
