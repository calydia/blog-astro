---
import type BlogData from '../interfaces/blogHighlight';

const {
  authorImage,
  authorName,
  authorContent,
  categoryName,
  categoryUrl,
  featuredCategoryPost,
  relatedPosts,
  currentSlug,
} = Astro.props as {
  authorImage: string;
  authorName: string;
  authorContent: string;
  categoryName: string;
  categoryUrl: string;
  featuredCategoryPost?: BlogData;
  relatedPosts: BlogData[];
  currentSlug: string;
};

const sidebarRelatedPosts = relatedPosts.filter((post) => post.slug !== currentSlug).slice(0, 2);
const showFeaturedCategoryPost = featuredCategoryPost && featuredCategoryPost.slug !== currentSlug;
---

<div class="grid gap-6">
  {(showFeaturedCategoryPost || sidebarRelatedPosts.length > 0) && (
    <section class="p-5 md:p-6 bg-lt-blue-light text-lt-gray dark:bg-dk-purple dark:text-white border-solid border-4 gradient-border-light dark:gradient-border-dark">
      <p class="sidebar-kicker text-lt-gray-box dark:text-dk-gray">Keep reading</p>

      {showFeaturedCategoryPost && (
        <div class="sidebar-block">
          <h2 class="sidebar-heading">
            Start here in {categoryName}
          </h2>
          <a href={`/${featuredCategoryPost.category.toLowerCase()}${featuredCategoryPost.slug}`} class="post-link no-underline">
            <span class="post-title sidebar-link-title">{featuredCategoryPost.title}</span>
          </a>
        </div>
      )}

      {sidebarRelatedPosts.length > 0 && (
        <div class="sidebar-block">
          <h2 class="sidebar-heading">Related posts</h2>
          <ul class="m-0 p-0 grid gap-3" role="list">
            {sidebarRelatedPosts.map((post) => (
              <li>
                <a href={`/${post.category.toLowerCase()}${post.slug}`} class="post-link no-underline">
                  <span class="post-title sidebar-link-title">{post.title}</span>
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <a href={`/${categoryUrl}`} class="sidebar-category-link no-underline">
        Browse {categoryName} posts
      </a>
    </section>
  )}

  <section>
    <div class="p-5 md:p-6 text-center text-lg bg-lt-blue-light text-lt-gray dark:bg-dk-purple dark:text-white border-solid border-4 gradient-border-light dark:gradient-border-dark">
      <p class="sidebar-kicker text-lt-gray-box dark:text-dk-gray">About the author</p>
      <div class="mb-4">
        <img
          src={authorImage}
          alt=""
          width={150}
          height={150}
          class="rounded-full mx-auto w-[120px] h-[120px] object-cover border-4 border-lt-purple dark:border-dk-blue-light"
          loading="lazy"
          decoding="async"
        />
      </div>
      <span class="font-title text-2xl text-lt-gray-box dark:text-dk-gray">{authorName}</span>
      <div class="sidebar-author-copy text-lg max-w-xl mx-auto text-lt-gray-box dark:text-dk-gray"><Fragment set:html={authorContent} /></div>
    </div>
  </section>
</div>

<style>
  .sidebar-kicker {
    margin-top: 0;
    margin-bottom: 0.5rem;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .sidebar-block + .sidebar-block {
    margin-top: 1.25rem;
  }

  .sidebar-heading {
    margin-top: 0;
    margin-bottom: 0.5rem;
    font-size: 1.15rem;
    line-height: 1.3;
  }

  .sidebar-link-title {
    display: block;
    font-size: 1rem;
    line-height: 1.45;
  }

  .sidebar-category-link {
    display: block;
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 2px solid currentColor;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.4;
  }

  .sidebar-category-link:hover,
  .sidebar-category-link:focus-visible {
    text-decoration: underline;
    text-underline-offset: 0.25rem;
  }

  .sidebar-author-copy :global(p) {
    margin-top: 1rem;
    margin-bottom: 0;
  }
</style>
